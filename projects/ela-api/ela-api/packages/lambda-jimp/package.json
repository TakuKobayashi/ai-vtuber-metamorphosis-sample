{
  "name": "@ela-api/lambda-jimp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "tsc && cp package.json dist/",
    "start": "node dist/index.js",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "package": "npm run build && cd dist && zip -r ../lambda-jimp.zip . && cd ..",
    "deploy": "aws lambda update-function-code --function-name ela-api-jimp --zip-file fileb://lambda-jimp.zip"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.3",
    "hono": "^4.7.10",
    "jimp": "^1.6.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.149",
    "@types/node": "^22.15.21",
    "prettier": "^3.5.3",
    "typescript": "^5.8.3"
  }
}
